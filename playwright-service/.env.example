# =============================================================================
# Xero BAS/IAS Automation Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# Encryption key for session cookie storage (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-32-byte-fernet-key-here-change-me

# API key for authenticating requests to this service
API_KEY=change-this-api-key-in-production

# Playwright settings
PLAYWRIGHT_TIMEOUT=30000
HEADLESS=true

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# OneDrive (local filesystem sync path)
ONE_DRIVE_FOLDER_ORIGIN=C:\Users\YourUser\OneDrive - Dexterous Group

# SharePoint URL derivation (for Asana comment links)
ONEDRIVE_LOCAL_PREFIX=Dexter's files - Bookkeeping & Accounting
SHAREPOINT_BASE_URL=https://dexterousgroup.sharepoint.com/sites/YourSite/Shared%20Documents/Bookkeeping%20%26%20Accounting

# Directories (Docker paths by default, override for local dev)
DOWNLOAD_DIR=/app/downloads
SCREENSHOT_DIR=/app/screenshots
SESSION_DIR=/app/sessions

# Screenshot settings
DEBUG_SCREENSHOTS=false
SCREENSHOT_RETENTION_DAYS=7

# Logging
LOG_LEVEL=INFO

# Xero credentials (for automated login)
XERO_EMAIL=your-xero-email@example.com
XERO_PASSWORD=your-xero-password

# Xero security question answers (for MFA bypass during automated login)
XERO_SECURITY_ANSWER_1=
XERO_SECURITY_ANSWER_2=
XERO_SECURITY_ANSWER_3=

# =============================================================================
# Asana Integration
# =============================================================================

# Asana API token (Personal Access Token)
ASANA_API_KEY=

# IAS Asana config
IAS_ASANA_SECTION_GID=                # "Ready to Export" section GID
IAS_ASANA_REASSIGNEE_GID=             # Person GID to reassign IAS tasks to

# BAS Asana config
BAS_ASANA_SECTION_GID=                # "Ready to Prepare" section GID
BAS_ASANA_REASSIGNEE_GID=             # Person GID to reassign BAS tasks to
BAS_ASANA_TEAM_GID=                   # Income Tax team GID to @mention in BAS comments

# =============================================================================
# Email Fallback (sent when Asana update fails)
# =============================================================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_FALLBACK_EMAIL=

# Optional: n8n webhook for notifications
N8N_WEBHOOK_URL=
